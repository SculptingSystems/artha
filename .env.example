# LLM Provider: anthropic | openai | gemini | groq
LLM_PROVIDER=gemini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Google Gemini (free, get key at aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# Groq (free, get key at console.groq.com)
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Model names
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://artha:artha@localhost:5432/artha

# News API (free tier at newsapi.org)
NEWS_API_KEY=your-newsapi-key-here

# App settings
LOG_LEVEL=INFO
MAX_CANDIDATES=500
CACHE_TTL_SECONDS=300
